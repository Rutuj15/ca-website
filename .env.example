# Copy this file to .env.local and fill in real values.
# NEXT_PUBLIC_* vars are inlined at build time — set them on your host (e.g. Cloudflare) too.

NEXT_PUBLIC_FORMSPREE_ID=your-formspree-form-id
NEXT_PUBLIC_CAL_LINK=sakshi-ckb51f/15min
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GSC_VERIFICATION=your-google-search-console-token

# Sanity (blog CMS). projectId + dataset are public read-only values for
# published content. Get them from sanity.io/manage -> project -> API.
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: shared secret to protect /api/revalidate (Sanity webhook).
SANITY_REVALIDATE_SECRET=
